{
  "name": "@stratum-hq/db-adapters",
  "version": "0.2.4",
  "description": "Stratum PostgreSQL adapters for tenant-scoped query isolation",
  "keywords": [
    "multi-tenancy",
    "multi-tenant",
    "saas",
    "tenant",
    "tenant-isolation",
    "postgresql",
    "postgres",
    "row-level-security",
    "rls",
    "schema-isolation",
    "database",
    "stratum"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@stratum-hq/core": "*",
    "pg": "^8.11.0"
  },
  "peerDependencies": {
    "drizzle-orm": ">=0.29.0"
  },
  "peerDependenciesMeta": {
    "drizzle-orm": {
      "optional": true
    }
  },
  "devDependencies": {
    "@prisma/client": "^5.10.0",
    "@types/pg": "^8.11.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
