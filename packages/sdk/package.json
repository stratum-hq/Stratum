{
  "name": "@stratum-hq/sdk",
  "version": "0.2.3",
  "description": "Stratum Node.js SDK for multi-tenant context propagation",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
