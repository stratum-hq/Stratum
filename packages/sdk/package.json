  },
  "dependencies": {
    "@stratum-hq/core": "*",
    "lru-cache": "^10.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "express": "^4.18.0",
    "fastify": "^5.3.2",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
