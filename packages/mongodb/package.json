{
  "name": "@stratum-hq/mongodb",
  "version": "0.1.0",
  "description": "MongoDB tenant isolation for Stratum — shared collection, collection-per-tenant, and database-per-tenant strategies",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@stratum-hq/core": "*",
    "@stratum-hq/sdk": "*"
  },
  "peerDependencies": {
    "mongodb": "^6.0.0 || ^7.0.0"
  },
  "peerDependenciesMeta": {
    "mongoose": {
      "optional": true
    }
  },
  "devDependencies": {
    "mongodb": "^6.12.0",
    "mongoose": "^8.0.0",
    "typescript": "^5.9.0",
    "vitest": "^1.6.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
