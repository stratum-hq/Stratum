    "@fastify/swagger-ui": "^3.0.0",
    "@stratum/core": "*",
    "@stratum/lib": "*",
    "fastify": "^4.28.0",
    "jsonwebtoken": "^9.0.0",
    "pg": "^8.11.0",
    "zod-to-json-schema": "^3.22.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.0",
    "@types/pg": "^8.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
