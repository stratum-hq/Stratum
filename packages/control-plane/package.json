{
  "name": "@stratum-hq/control-plane",
  "version": "0.2.4",
  "description": "Stratum control plane REST API server",
  "keywords": [
    "multi-tenancy",
    "multi-tenant",
    "saas",
    "tenant",
    "tenant-management",
    "rest-api",
    "control-plane",
    "fastify",
    "node",
    "typescript",
    "stratum"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "migrate": "tsx src/db/migrate.ts"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@fastify/cors": "^11.0.0",
    "@fastify/helmet": "^13.0.0",
    "@fastify/rate-limit": "^10.2.0",
    "@fastify/swagger": "^9.4.0",
    "@fastify/swagger-ui": "^5.2.0",
    "@stratum-hq/core": "*",
    "@stratum-hq/lib": "*",
    "fastify": "^5.3.2",
    "jsonwebtoken": "^9.0.0",
    "ioredis": "^5.4.0",
    "pg": "^8.11.0",
    "zod": "^3.22.0",
    "zod-to-json-schema": "^3.22.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.0",
    "@types/pg": "^8.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
