{
  "name": "@stratum-hq/create",
  "version": "0.2.3",
  "description": "Create a new Stratum multi-tenancy project",
  "keywords": [
    "multi-tenancy",
    "multi-tenant",
    "saas",
    "tenant",
    "create",
    "scaffolding",
    "starter",
    "boilerplate",
    "node",
    "typescript",
    "stratum"
  ],
  "bin": {
    "create-stratum": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./matrix": {
      "import": "./src/matrix.ts",
      "types": "./src/matrix.ts"
    }
  },
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:@stratum-hq/*",
    "test": "vitest run"
  },
  "devDependencies": {
    "esbuild": "^0.20.0",
    "vitest": "^1.6.0",
    "typescript": "^5.3.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/stratum-hq/Stratum.git",
    "directory": "packages/create"
  }
}
