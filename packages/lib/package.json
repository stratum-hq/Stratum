{
  "name": "@stratum-hq/lib",
  "version": "0.2.3",
  "description": "Stratum tenant management library - framework-agnostic business logic",
  "keywords": [
    "multi-tenancy",
    "multi-tenant",
    "saas",
    "b2b",
    "tenant",
    "tenant-management",
    "tenant-isolation",
    "node",
    "typescript",
    "postgresql",
    "row-level-security",
    "rls",
    "schema-isolation",
    "config-inheritance",
    "gdpr",
    "stratum"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && cp -r src/migrations dist/migrations",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@stratum-hq/core": "*",
    "@stratum-hq/sdk": "*",
    "pg": "^8.11.0"
  },
  "peerDependencies": {
    "@opentelemetry/api": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/api": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/pg": "^8.11.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
