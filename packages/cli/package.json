{
  "name": "@stratum-hq/cli",
  "version": "0.2.3",
  "description": "Stratum CLI — project scaffolding, database migration, and developer tools",
  "keywords": [
    "multi-tenancy",
    "multi-tenant",
    "saas",
    "tenant",
    "cli",
    "scaffolding",
    "migration",
    "postgresql",
    "node",
    "typescript",
    "stratum"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "stratum": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run --passWithNoTests",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@stratum-hq/core": "*",
    "pg": "^8.11.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/pg": "^8.11.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
