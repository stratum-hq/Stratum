{
  "name": "@stratum/demo",
  "version": "0.1.0",
  "private": true,
  "description": "Stratum demo application - MSSP hierarchy with tenant isolation",
  "scripts": {
    "build": "npm run build:api && npm run build:web",
    "build:api": "tsc -p api/tsconfig.json",
    "build:web": "cd web && npx vite build",
    "start": "concurrently \"npm run start:api\" \"npm run start:web\"",
    "start:api": "node api/dist/index.js",
    "start:web": "cd web && npx vite",
    "dev": "concurrently \"tsx watch api/src/index.ts\" \"cd web && npx vite\"",
    "seed": "tsx api/src/seed.ts",
    "test": "echo \"Demo: no tests\"",
    "lint": "tsc -p api/tsconfig.json --noEmit",
    "clean": "rm -rf api/dist web/dist"
  },
  "dependencies": {
    "@stratum/core": "*",
    "@stratum/db-adapters": "*",
    "@stratum/react": "*",
    "@stratum/sdk": "*",
    "@types/cors": "^2.8.19",
    "cors": "^2.8.6",
    "express": "^4.18.0",
    "jsonwebtoken": "^9.0.0",
    "pg": "^8.11.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/pg": "^8.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0"
  }
}
