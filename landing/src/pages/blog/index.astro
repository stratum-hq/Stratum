---
import Base from '../../layouts/Base.astro';
import '../../styles/global.css';
---

<Base title="Blog — Stratum" description="Updates, guides, and insights about multi-tenancy in Node.js from the Stratum team.">

<!-- Nav -->
<nav class="nav">
  <div class="nav-inner">
    <a href="/" class="nav-logo">
      <img src="/favicon.png" alt="Stratum" class="nav-logo-img" width="28" height="28" />
      Stratum
    </a>
    <div class="nav-links">
      <a href="/what-is-stratum">What is Stratum?</a>
      <a href="/blog" aria-current="page">Blog</a>
      <a href="https://docs.stratum-hq.org">Docs</a>
      <a href="https://github.com/stratum-hq/Stratum">GitHub</a>
      <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/>
          <line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/>
          <line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
      </button>
    </div>
  </div>
</nav>

<!-- Blog index -->
<main class="blog-index">
  <header class="blog-header">
    <p class="blog-eyebrow">Blog</p>
    <h1>Updates &amp; Insights</h1>
    <p class="blog-subtitle">Thoughts on multi-tenancy, Node.js, and building Stratum in the open.</p>
  </header>

  <ul class="post-list">
    <li class="post-card">
      <a href="/blog/why-we-built-stratum" class="post-card-link">
        <time class="post-date" datetime="2026-03-27">March 27, 2026</time>
        <h2 class="post-title">Why We Built Stratum</h2>
        <p class="post-description">Every B2B SaaS team reinvents multi-tenancy from scratch. We built Stratum so they never have to again.</p>
        <span class="post-read-more">Read post →</span>
      </a>
    </li>
  </ul>
</main>

<!-- Footer -->
<footer class="footer">
  <div class="footer-inner">
    <p class="footer-meta">
      MIT License &middot; &copy; <a href="https://github.com/stratum-hq">Stratum HQ</a>
    </p>
    <div class="footer-links">
      <a href="https://docs.stratum-hq.org">Docs</a>
      <a href="https://github.com/stratum-hq/Stratum">GitHub</a>
      <a href="https://www.npmjs.com/org/stratum-hq">npm</a>
    </div>
  </div>
</footer>

<style>
  .blog-index {
    max-width: 700px;
    margin: 0 auto;
    padding: calc(var(--space-8) * 2) var(--space-6) var(--space-8);
  }

  .blog-header {
    margin-bottom: var(--space-8);
  }

  .blog-eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--sandstone);
    margin-bottom: var(--space-3);
  }

  .blog-header h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    line-height: 1.2;
    color: var(--text-primary);
    margin-bottom: var(--space-4);
  }

  .blog-subtitle {
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin: 0;
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .post-card {
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    transition: border-color var(--duration-fast) var(--ease-out);
  }

  .post-card:hover {
    border-color: var(--border-hover);
  }

  .post-card-link {
    display: block;
    padding: var(--space-6);
    text-decoration: none;
    color: inherit;
  }

  .post-date {
    display: block;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-tertiary);
    margin-bottom: var(--space-2);
  }

  .post-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--space-3);
    line-height: 1.3;
  }

  .post-description {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--text-secondary);
    margin-bottom: var(--space-4);
  }

  .post-read-more {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--sandstone);
  }

  @media (max-width: 640px) {
    .blog-index {
      padding: var(--space-8) var(--space-4);
    }
  }
</style>

<!-- Theme toggle -->
<script>
  const toggle = document.getElementById('theme-toggle');
  const html = document.documentElement;

  function setTheme(theme: string) {
    html.setAttribute('data-theme', theme);
    localStorage.setItem('theme', theme);
  }

  const saved = localStorage.getItem('theme');
  if (saved) setTheme(saved);

  toggle?.addEventListener('click', () => {
    const current = html.getAttribute('data-theme');
    setTheme(current === 'light' ? 'dark' : 'light');
  });
</script>

</Base>
