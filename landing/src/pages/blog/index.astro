---
import Base from '../../layouts/Base.astro';
import '../../styles/global.css';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---

<Base title="Blog — Stratum" description="Updates, guides, and insights about multi-tenancy in Node.js from the Stratum team.">

<Nav />

<!-- Blog index -->
<main class="blog-index">
  <header class="blog-header">
    <p class="blog-eyebrow">Blog</p>
    <h1>Updates &amp; Insights</h1>
    <p class="blog-subtitle">Thoughts on multi-tenancy, Node.js, and building Stratum in the open.</p>
    <div class="blog-feeds">
      <a href="/rss.xml" class="blog-feed-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
        RSS
      </a>
      <a href="/atom.xml" class="blog-feed-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4.9 19.1C1 15.2 1 8.8 4.9 4.9"/><path d="M7.8 16.2c-2.3-2.3-2.3-6.1 0-8.5"/><circle cx="12" cy="12" r="2"/><path d="M16.2 7.8c2.3 2.3 2.3 6.1 0 8.5"/><path d="M19.1 4.9C23 8.8 23 15.1 19.1 19"/></svg>
        Atom
      </a>
    </div>
  </header>

  <ul class="post-list">
    <li class="post-card">
      <a href="/blog/whats-next-for-stratum" class="post-card-link">
        <time class="post-date" datetime="2026-03-27">March 27, 2026</time>
        <h2 class="post-title">What's Next for Stratum</h2>
        <p class="post-description">We shipped the foundation. Now we're listening for issues, hardening security, and building what developers actually need.</p>
        <span class="post-read-more">Read post →</span>
      </a>
    </li>
    <li class="post-card">
      <a href="/blog/why-we-built-stratum" class="post-card-link">
        <time class="post-date" datetime="2026-03-27">March 27, 2026</time>
        <h2 class="post-title">Why We Built Stratum</h2>
        <p class="post-description">Every B2B SaaS team reinvents multi-tenancy from scratch. We built Stratum so they never have to again.</p>
        <span class="post-read-more">Read post →</span>
      </a>
    </li>
  </ul>
</main>

<Footer />

<style>
  .blog-index {
    max-width: 700px;
    margin: 0 auto;
    padding: calc(var(--space-8) * 4) var(--space-6) var(--space-8);
    flex: 1;
  }

  .blog-header {
    margin-bottom: var(--space-8);
  }

  .blog-eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--sandstone);
    margin-bottom: var(--space-3);
  }

  .blog-header h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    line-height: 1.2;
    color: var(--text-primary);
    margin-bottom: var(--space-4);
  }

  .blog-subtitle {
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin: 0;
  }

  .blog-feeds {
    display: flex;
    gap: var(--space-3);
    margin-top: var(--space-4);
  }

  .blog-feed-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text-tertiary);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .blog-feed-link:hover {
    color: var(--sandstone);
  }

  .blog-feed-link:focus-visible {
    outline: 2px solid var(--sandstone);
    outline-offset: 2px;
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .post-card {
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    transition: border-color var(--duration-fast) var(--ease-out);
  }

  .post-card:hover {
    border-color: var(--border-hover);
  }

  .post-card-link {
    display: block;
    padding: var(--space-6);
    text-decoration: none;
    color: inherit;
  }

  .post-date {
    display: block;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-tertiary);
    margin-bottom: var(--space-2);
  }

  .post-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--space-3);
    line-height: 1.3;
  }

  .post-description {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--text-secondary);
    margin-bottom: var(--space-4);
  }

  .post-read-more {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--sandstone);
  }

  @media (max-width: 640px) {
    .blog-index {
      padding: var(--space-8) var(--space-4);
    }
  }
</style>


</Base>
