---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<Base title="Contact Stratum -- Report Bugs, Request Features, Get in Touch" description="Reach the Stratum team via GitHub Issues for bugs and features, or email for business inquiries.">

<Nav />

<section class="contact">
  <h1>Get in <span class="accent">touch</span></h1>

  <div class="contact-section">
    <h2>Bugs and feature requests</h2>
    <p>The best way to report issues or suggest features is through GitHub. Every issue gets read.</p>
    <a href="https://github.com/stratum-hq/Stratum/issues" class="contact-link">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
      Open a GitHub Issue
    </a>
  </div>

  <div class="contact-section">
    <h2>Business inquiries</h2>
    <p>For partnerships, consulting, or anything that does not fit a GitHub issue.</p>
    <a href="mailto:contact@stratum-hq.org" class="contact-link">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
      contact@stratum-hq.org
    </a>
  </div>

  <div class="contact-section">
    <h2>Stay updated</h2>
    <p>Follow the blog for release notes, guides, and project updates. Available via RSS and Atom feeds.</p>
    <div class="contact-link-group">
      <a href="/blog" class="contact-link">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
        Blog
      </a>
      <a href="/rss.xml" class="contact-link">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
        RSS Feed
      </a>
      <a href="/atom.xml" class="contact-link">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4.9 19.1C1 15.2 1 8.8 4.9 4.9"/><path d="M7.8 16.2c-2.3-2.3-2.3-6.1 0-8.5"/><circle cx="12" cy="12" r="2"/><path d="M16.2 7.8c2.3 2.3 2.3 6.1 0 8.5"/><path d="M19.1 4.9C23 8.8 23 15.1 19.1 19"/></svg>
        Atom Feed
      </a>
    </div>
  </div>
</section>

<!-- ContactPage structured data -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Contact Stratum",
  "url": "https://stratum-hq.org/contact",
  "mainEntity": {
    "@type": "Organization",
    "name": "Stratum HQ",
    "url": "https://stratum-hq.org",
    "email": "contact@stratum-hq.org",
    "sameAs": [
      "https://github.com/stratum-hq",
      "https://www.npmjs.com/org/stratum-hq"
    ]
  }
}
</script>

<Footer />

<style>
  .contact {
    max-width: 700px;
    margin: 0 auto;
    padding: var(--space-16) var(--space-6) var(--space-8);
  }

  .contact h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    line-height: 1.2;
    color: var(--text-primary);
    margin-bottom: var(--space-8);
  }

  .contact-section {
    margin-bottom: var(--space-8);
  }

  .contact-section h2 {
    font-size: 1.375rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--space-3);
  }

  .contact-section p {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--text-secondary);
    margin-bottom: var(--space-4);
  }

  .contact-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    background: var(--surface-1);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--sandstone);
    font-size: 0.9375rem;
    text-decoration: none;
    min-height: 44px;
    transition: border-color var(--duration-fast) var(--ease-out),
                background var(--duration-fast) var(--ease-out);
  }

  .contact-link:hover {
    border-color: var(--border-hover);
    background: var(--surface-2);
  }

  .contact-link:focus-visible {
    outline: 2px solid var(--sandstone);
    outline-offset: 2px;
  }

  .contact-link:active {
    background: var(--surface-3);
  }

  .contact-link svg {
    flex-shrink: 0;
  }

  .contact-link-group {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  @media (max-width: 640px) {
    .contact {
      padding: var(--space-8) var(--space-4);
    }

    .contact-link-group {
      flex-direction: column;
    }

    .contact-link {
      width: 100%;
      justify-content: center;
    }
  }
</style>

</Base>
